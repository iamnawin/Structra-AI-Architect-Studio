{
  "name": "structra-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "structra": "./cli/index.js"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "dev:api": "node server/src/index.js",
    "dev:full": "bash -c \"npm run dev:api & npm run dev\"",
    "smoke": "node scripts/smoke.mjs",
    "cli": "node cli/index.js",
    "cli:setup": "node -e \"const fs=require('fs');if(!fs.existsSync('.env')){fs.copyFileSync('.env.example','.env');console.log('Created .env — add your ANTHROPIC_API_KEY');}else{console.log('.env already exists');}\" 2>/dev/null || ([ ! -f .env ] && cp .env.example .env && echo 'Created .env — add your ANTHROPIC_API_KEY' || echo '.env already exists')"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
