# ─── Structra CLI (computer-use AI assistant) ─────────────────────────────────

# Required: Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Claude model to use (defaults to claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Optional: Max tokens per response (default 8096)
# MAX_TOKENS=8096

# Optional: Disable computer use tools (screenshot / mouse / keyboard)
# COMPUTER_USE=false

# Optional: Disable the shell command safety classifier
# SHELL_SAFETY=false

# ─── Structra Web App (React + Express) ───────────────────────────────────────

# Required: Gemini AI API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# The URL where the app is hosted
APP_URL=http://localhost:3000

# Express API port
API_PORT=8787

# AI provider: "mock" (no cost, offline) or "gemini" (real AI calls)
AI_PROVIDER=mock

# Node environment
NODE_ENV=development
